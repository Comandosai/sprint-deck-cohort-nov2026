# =============================================================================
# Comandos Claw Deck — переменные окружения
# =============================================================================
# Скопируй: cp .env.example .env
# Заполни ключи. .env уже в .gitignore — НЕ коммитится.
# =============================================================================


# ===== МОДЕЛИ (4 ключа — обязательные) ===========================================

# 1. MiniMax — PRIMARY модель (через Coding Plan $10/мес фикс)
# Где: platform.minimax.io → Subscribe → Coding Plan Starter
MINIMAX_API_KEY=

# 2. DeepSeek — FALLBACK + PREMIUM (V4-Flash и V4-Pro)
# Где: api-docs.deepseek.com → Sign up → API key, закинь $10
DEEPSEEK_API_KEY=

# 3. OpenRouter — HEARTBEAT (Gemini Flash-Lite) + SUBAGENTS (Kimi K2.6)
# Где: openrouter.ai → Settings → API key, закинь $10
# КРИТИЧНО: в Settings включи Spending Limit $30/мес — это provider hard limit
OPENROUTER_API_KEY=

# 4. Groq — Whisper транскрипция голосовых (БЕСПЛАТНО, 30k минут/мес)
# Где: console.groq.com → API keys
GROQ_API_KEY=


# ===== TELEGRAM (2 значения — обязательные) =====================================

# Bot token через @BotFather → /newbot → название → username @xxx_bot → token
TELEGRAM_BOT_TOKEN=

# Свой числовой User ID (НЕ username) через @userinfobot
# Это нужно для dmPolicy: allowlist — только ты сможешь писать в DM
TELEGRAM_USER_ID=


# ===== VOICE (опционально) ======================================================

# OpenAI TTS — голосовые ответы (~$1-2/мес, tts-1, не tts-1-hd)
# Где: platform.openai.com → API keys
OPENAI_API_KEY=

# ElevenLabs — альтернатива TTS лучшего качества ($5/мес Starter)
# Где: elevenlabs.io
ELEVENLABS_API_KEY=


# ===== MCP-СЕРВЕРЫ (опционально) ================================================

# Tavily — продвинутый AI-поиск (есть free tier)
# Где: tavily.com → API key
TAVILY_API_KEY=

# Notion API — если будешь подключать MCP
# Где: notion.so/my-integrations
NOTION_API_KEY=

# GitHub PAT — если будешь подключать GitHub MCP
# Где: github.com/settings/tokens → Generate new token (classic)
# Scopes: repo, read:user
GITHUB_PAT=


# ===== VPS (для скриптов) =======================================================

# IP твоего VPS
VPS_IP=

# Пользователь на VPS (по умолчанию clawd, НЕ root)
VPS_USER=clawd

# SSH alias из ~/.ssh/config (опционально, иначе используется VPS_IP)
SSH_ALIAS=clawd-vps


# ===== РЕЖИМ DEBUG (опц.) =======================================================

OPENCLAW_DEBUG=0
